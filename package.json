{
  "name": "koulis",
  "version": "0.2.0",
  "main": "index.js",
  "type": "module",
  "bin": {
    "koulis-mcp": "./build/transports/stdio.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/transports/stdio.js', '755')\"",
    "start": "node build/index.js",
    "start:stdio": "node build/transports/stdio.js",
    "dev:http": "tsx --env-file=.env src/index.ts",
    "dev:stdio": "tsx --env-file=.env src/transports/stdio.ts",
    "inspect": "npx @modelcontextprotocol/inspector npx tsx --env-file=.env src/transports/stdio.ts",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "test \"$CI\" = 'true' || lefthook install"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "files": [
    "build"
  ],
  "engines": {
    "node": ">=22"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "The open restaurant booking protocol",
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.18",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@eslint/js": "^10.0.1",
    "@evilmartians/lefthook": "^2.1.6",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.5"
  }
}
